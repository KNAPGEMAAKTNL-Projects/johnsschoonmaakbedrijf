---
// Footer.astro - 4-column footer on navy bg with grain overlay
// DESIGN.md §5, §6, §7.6 + CONTENT/homepage.md §9

const year = new Date().getFullYear();
---

<footer class="bg-navy relative overflow-hidden" style="padding-top: 64px; padding-bottom: 32px;" transition:name="site-footer" transition:animate="none">
  <!-- Grain overlay -->
  <div class="absolute inset-0 pointer-events-none" style="opacity: 0.2;" aria-hidden="true">
    <svg width="100%" height="100%">
      <filter id="footer-grain">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
      </filter>
      <rect width="100%" height="100%" filter="url(#footer-grain)" />
    </svg>
  </div>

  <div class="max-w-[1360px] mx-auto px-5 md:px-10 relative z-10">
    <!-- Main grid: 2fr 1fr 1fr 1fr -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr] gap-10 lg:gap-12 mb-12">

      <!-- Brand column (wider) -->
      <div>
        <a href="/" class="font-head font-bold text-[18px] text-white inline-block mb-4">
          John's Schoonmaakbedrijf
        </a>
        <p class="text-white/60 text-[14px] leading-relaxed mb-5 max-w-xs">
          VCA-gecertificeerde kantoorschoonmaak vanuit Buren. Vaste teams, persoonlijk contact.
        </p>
        <!-- Footer badge -->
        <div class="flex flex-wrap gap-2">
          <span class="footer-badge">VCA-gecertificeerd</span>
        </div>
      </div>

      <!-- Diensten column -->
      <div>
        <h4 class="footer-col-title">Diensten</h4>
        <ul class="space-y-2.5">
          <li><a href="/diensten/kantoorschoonmaak/" class="footer-link">Kantoorschoonmaak</a></li>
          <li><a href="/diensten/glazenwassen/" class="footer-link">Glazenwassen</a></li>
          <li><a href="/diensten/bouw-oplevering/" class="footer-link">Bouw-oplevering</a></li>
          <li><a href="/diensten/zonnepanelen/" class="footer-link">Zonnepanelen</a></li>
          <li><a href="/diensten/dakgoten/" class="footer-link">Dakgoten</a></li>
          <li><a href="/diensten/gevelreiniging/" class="footer-link">Gevelreiniging</a></li>
        </ul>

        <h4 class="footer-col-title mt-8">Navigatie</h4>
        <ul class="space-y-2.5">
          <li><a href="/over-ons/" class="footer-link">Over ons</a></li>
          <li><a href="/faq/" class="footer-link">FAQ</a></li>
          <li><a href="/contact/" class="footer-link">Contact</a></li>
        </ul>
      </div>

      <!-- Regio's column -->
      <div>
        <h4 class="footer-col-title">Regio's</h4>
        <ul class="space-y-2.5">
          <li><span class="footer-link">Buren</span></li>
          <li><span class="footer-link">Tiel</span></li>
          <li><span class="footer-link">Culemborg</span></li>
          <li><span class="footer-link">Geldermalsen</span></li>
          <li><span class="footer-link">Elst</span></li>
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h4 class="footer-col-title">Contact</h4>
        <ul class="space-y-2.5">
          <li>
            <a href="tel:0623545276" class="footer-link flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0 text-primary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              06 23545276
            </a>
          </li>
          <li>
            <a href="mailto:info@johnsschoonmaakbedrijf.nl" class="footer-link flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0 text-primary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              info@johnsschoonmaakbedrijf.nl
            </a>
          </li>
          <li>
            <span class="footer-link flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0 text-primary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Randweg 32, Buren
            </span>
          </li>
          <li class="pt-2">
            <p class="text-white/40 text-[12px]">Ma–vr: 08:00 – 18:00 · Za: 08:00 – 12:00</p>
          </li>
        </ul>
      </div>
    </div>

    <!-- Footer bottom -->
    <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div class="text-white/40 text-[13px]">
        <p>&copy; {year} John's Schoonmaakbedrijf &middot; KvK 55028330</p>
        <p class="mt-1">Servicegebied: Buren en omgeving</p>
      </div>
      <div class="flex gap-6 text-[13px]">
        <a href="/privacybeleid/" class="text-white/40 hover:text-white/70 transition-colors">Privacybeleid</a>
        <a href="/algemene-voorwaarden/" class="text-white/40 hover:text-white/70 transition-colors">Algemene voorwaarden</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-col-title {
    font-family: var(--font-head);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: white;
    margin-bottom: 16px;
  }
  .footer-link {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.2s;
    display: inline-flex;
  }
  a.footer-link:hover {
    color: rgba(255, 255, 255, 0.9);
  }
  .footer-badge {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-accent);
    background: rgba(250, 204, 21, 0.12);
    border: 1px solid rgba(250, 204, 21, 0.2);
    padding: 4px 10px;
    border-radius: 9999px;
  }
</style>
