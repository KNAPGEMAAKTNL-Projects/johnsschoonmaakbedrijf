---
// Header.astro - Sticky nav with dropdown, active page, backdrop-blur, accessible mobile menu

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}

const navLinks = [
  { href: "/over-ons/", label: "Over ons" },
  { href: "/faq/", label: "FAQ" },
  { href: "/contact/", label: "Contact" },
];

const services = [
  { href: "/diensten/kantoorschoonmaak/", label: "Kantoorschoonmaak" },
  { href: "/diensten/glazenwassen/", label: "Glazenwassen" },
  { href: "/diensten/bouw-oplevering/", label: "Opleveringsschoonmaak" },
  { href: "/diensten/zonnepanelen/", label: "Zonnepanelen reinigen" },
  { href: "/diensten/dakgoten/", label: "Dakgoten leegmaken" },
  { href: "/diensten/gevelreiniging/", label: "Gevelreiniging" },
];
---

<header
  class="sticky top-0 z-[100] bg-bg/95 backdrop-blur-sm border-b border-border"
  transition:name="site-header"
  transition:animate="none"
>
  <input type="checkbox" id="nav-toggle" class="peer hidden" aria-hidden="true" />

  <!-- Backdrop overlay for mobile menu -->
  <label
    for="nav-toggle"
    class="fixed inset-0 bg-navy/20 z-40 hidden peer-checked:block lg:hidden cursor-default"
    aria-hidden="true"
  ></label>

  <div class="max-w-[1360px] mx-auto px-5 md:px-10 h-[72px] flex items-center justify-between">
    <a href="/" class="font-head font-bold text-[18px] text-text shrink-0" transition:name="site-logo">
      John's Schoonmaakbedrijf
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Hoofdmenu">
      <!-- Diensten dropdown -->
      <div class="relative group">
        <a
          href="/diensten/"
          class:list={[
            "text-[14px] font-medium transition-colors duration-200 flex items-center gap-1",
            isActive("/diensten/") ? "text-primary" : "text-text-muted hover:text-primary",
          ]}
          aria-current={isActive("/diensten/") ? "page" : undefined}
        >
          Diensten
          <svg class="w-3 h-3 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
        <!-- Dropdown panel -->
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          <div class="bg-bg border border-border rounded-lg shadow-lift p-2 min-w-[220px]" style="border-radius: var(--radius-lg);">
            {services.map((s) => (
              <a
                href={s.href}
                class:list={[
                  "block px-3 py-2 text-[13px] font-medium rounded-md transition-colors duration-150",
                  pathname === s.href ? "text-primary bg-surface-blue" : "text-text-muted hover:text-primary hover:bg-surface-blue",
                ]}
              >
                {s.label}
              </a>
            ))}
            <hr class="my-1.5 border-border-light" />
            <a href="/diensten/" class="block px-3 py-2 text-[13px] font-semibold text-primary rounded-md hover:bg-surface-blue transition-colors duration-150">
              Alle diensten &rarr;
            </a>
          </div>
        </div>
      </div>

      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-[14px] font-medium transition-colors duration-200",
            isActive(link.href) ? "text-primary" : "text-text-muted hover:text-primary",
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Desktop phone + CTA -->
    <div class="hidden lg:flex items-center gap-5">
      <a href="tel:0623545276" class="text-[14px] font-semibold text-text-muted hover:text-primary transition-colors duration-200 flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        06 23545276
      </a>
      <a href="/contact/" class="bg-primary text-white font-head text-[13px] font-semibold px-5 py-2.5 rounded-full hover:bg-navy hover:shadow-btn hover:-translate-y-px transition-all duration-200">
        Offerte aanvragen
      </a>
    </div>

    <!-- Mobile hamburger -->
    <label for="nav-toggle" class="lg:hidden cursor-pointer p-2.5 -mr-2 text-text min-w-[44px] min-h-[44px] flex items-center justify-center" aria-label="Menu openen">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>
  </div>

  <!-- Mobile menu -->
  <div class="fixed inset-x-0 top-[72px] bottom-0 bg-bg z-50 translate-x-full peer-checked:translate-x-0 transition-transform duration-300 ease-out lg:hidden overflow-y-auto border-t border-border">
    <nav class="flex flex-col p-6 gap-1" aria-label="Mobiel menu">
      <!-- Diensten with sub-links -->
      <a
        href="/diensten/"
        class:list={[
          "nav-mobile-link py-3 px-4 text-[16px] font-medium rounded-lg transition-colors min-h-[44px] flex items-center",
          isActive("/diensten/") ? "text-primary bg-surface-blue" : "text-text hover:text-primary hover:bg-surface-blue",
        ]}
      >
        Diensten
      </a>
      <div class="pl-4 space-y-0.5 mb-2">
        {services.map((s) => (
          <a
            href={s.href}
            class:list={[
              "nav-mobile-link block py-2 px-4 text-[14px] rounded-lg transition-colors min-h-[40px] flex items-center",
              pathname === s.href ? "text-primary font-medium" : "text-text-muted hover:text-primary hover:bg-surface-blue",
            ]}
          >
            {s.label}
          </a>
        ))}
      </div>

      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "nav-mobile-link py-3 px-4 text-[16px] font-medium rounded-lg transition-colors min-h-[44px] flex items-center",
            isActive(link.href) ? "text-primary bg-surface-blue" : "text-text hover:text-primary hover:bg-surface-blue",
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}

      <hr class="my-4 border-border" />

      <a href="tel:0623545276" class="py-3 px-4 text-[16px] font-semibold text-text-muted flex items-center gap-2.5 min-h-[44px]">
        <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        06 23545276
      </a>

      <a href="/contact/" class="mt-4 bg-primary text-white font-head text-[15px] font-semibold px-7 py-3.5 rounded-full text-center hover:bg-navy transition-all duration-200 min-w-[200px] min-h-[44px] flex items-center justify-center">
        Offerte aanvragen
      </a>
    </nav>
  </div>
</header>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById("nav-toggle") as HTMLInputElement;
    if (!toggle) return;
    document.querySelectorAll(".nav-mobile-link").forEach((link) => {
      link.addEventListener("click", () => { toggle.checked = false; });
    });
  }
  document.addEventListener("astro:page-load", initMobileMenu);
</script>
