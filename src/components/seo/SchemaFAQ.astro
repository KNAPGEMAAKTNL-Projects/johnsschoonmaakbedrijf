---
/**
 * SchemaFAQ.astro
 * Generates FAQPage JSON-LD from an array of Q&A pairs.
 * CRITICAL: The question/answer text must EXACTLY match visible page content.
 */

interface Props {
  faqs: Array<{ question: string; answer: string }>;
}

const { faqs } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---

<script
  type="application/ld+json"
  set:html={JSON.stringify(schema, null, 0)}
/>
