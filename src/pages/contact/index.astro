---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ContactForm from "../../components/ContactForm.astro";
---

<Layout title="Contact · Offerte aanvragen | John's Schoonmaakbedrijf" description="Neem contact op met John's Schoonmaakbedrijf in Buren. Bel, WhatsApp of vraag een vrijblijvende offerte aan. Reactie binnen 24 uur.">
  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-surface-blue" style="padding-top: 64px; padding-bottom: 48px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">
        <nav class="text-[13px] text-text-muted mb-6" aria-label="Breadcrumb">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span class="text-text">Contact</span>
        </nav>
        <h1>Neem gerust contact op</h1>
        <p class="text-text-muted text-[17px] mt-4 max-w-xl" style="line-height: 1.7;">Laat weten wat wij voor uw bedrijf kunnen betekenen. Bel ons, stuur een bericht of vul het formulier in. Binnen 24 uur hoort u van ons.</p>
      </div>
    </section>

    <!-- Contact content: 4fr 5fr (business details left, form right - reversed from homepage for variety) -->
    <section class="bg-bg" style="padding-top: 64px; padding-bottom: 96px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-[4fr_5fr] gap-10 lg:gap-16">

          <!-- Left: business details -->
          <div class="scroll-fade-up space-y-8">

            <!-- Contact methods -->
            <div class="space-y-4">
              <h2 class="text-[22px] font-bold mb-4">Bereik ons</h2>

              <a href="tel:0623545276" class="card-lift flex items-center gap-4 p-4 bg-surface rounded-lg border border-border transition-all" style="border-radius: var(--radius-md);">
                <div class="w-10 h-10 rounded-md flex items-center justify-center shrink-0" style="border-radius: var(--radius-md); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));">
                  <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-[13px] font-semibold text-text">Bellen</p>
                  <p class="text-[14px] text-text-muted">Direct contact met John</p>
                  <p class="text-[15px] font-semibold text-primary mt-0.5">06 23545276</p>
                </div>
              </a>

              <a href="https://wa.me/31623545276" target="_blank" rel="noopener" class="card-lift flex items-center gap-4 p-4 bg-surface rounded-lg border border-border transition-all" style="border-radius: var(--radius-md);">
                <div class="w-10 h-10 rounded-md flex items-center justify-center shrink-0" style="border-radius: var(--radius-md); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));">
                  <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-[13px] font-semibold text-text">WhatsApp</p>
                  <p class="text-[14px] text-text-muted">Stuur een bericht</p>
                </div>
              </a>

              <a href="mailto:info@johnsschoonmaakbedrijf.nl" class="card-lift flex items-center gap-4 p-4 bg-surface rounded-lg border border-border transition-all" style="border-radius: var(--radius-md);">
                <div class="w-10 h-10 rounded-md flex items-center justify-center shrink-0" style="border-radius: var(--radius-md); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));">
                  <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-[13px] font-semibold text-text">E-mail</p>
                  <p class="text-[14px] text-text-muted">We reageren binnen 24 uur</p>
                  <p class="text-[14px] text-primary mt-0.5">info@johnsschoonmaakbedrijf.nl</p>
                </div>
              </a>
            </div>

            <!-- Address + hours -->
            <div class="p-6 bg-surface rounded-lg border border-border" style="border-radius: var(--radius-lg);">
              <h3 class="font-head text-[16px] font-bold text-text mb-3">Adres</h3>
              <address class="not-italic text-[14px] text-text-muted leading-relaxed mb-4">
                John's Schoonmaakbedrijf<br>
                Randweg 32<br>
                4116 GH Buren<br>
                Gelderland
              </address>

              <h3 class="font-head text-[16px] font-bold text-text mb-3">Bereikbaar</h3>
              <p class="text-[14px] text-text-muted">Maandag t/m vrijdag: 08:00 – 18:00</p>
              <p class="text-[14px] text-text-muted">Zaterdag: 08:00 – 12:00</p>
              <p class="text-[14px] text-text-muted">Zondag: gesloten</p>

              <div class="mt-4 pt-4 border-t border-border">
                <p class="text-[12px] text-text-light">KvK: 55028330</p>
              </div>
            </div>

            <!-- Google Maps embed -->
            <div class="rounded-lg overflow-hidden border border-border" style="border-radius: var(--radius-lg); aspect-ratio: 16/10;">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2466.5!2d5.3311!3d51.9116!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sRandweg+32%2C+4116+GH+Buren!5e0!3m2!1snl!2snl!4v1"
                class="w-full h-full border-0"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="John's Schoonmaakbedrijf op Google Maps"
              ></iframe>
            </div>

            <!-- Werkgebied -->
            <p class="text-[14px] text-text-muted">Wij zijn actief in de Betuwe en omstreken. Denk aan Buren, Tiel, Culemborg, Geldermalsen en Elst.</p>
          </div>

          <!-- Right: form -->
          <div class="scroll-fade-up">
            <ContactForm />
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
