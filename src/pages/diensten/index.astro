---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CtaSection from "../../components/CtaSection.astro";
import SchemaFAQ from "../../components/seo/SchemaFAQ.astro";

const faqs = [
  { question: "Welke schoonmaakdiensten bieden jullie aan?", answer: "Kantoorschoonmaak, glazenwassen, opleveringsschoonmaak, zonnepanelen reinigen, dakgoten leegmaken en gevelreiniging. Van regulier onderhoud tot eenmalige klussen." },
  { question: "Kunnen meerdere diensten gecombineerd worden?", answer: "Ja, dat kan. Kantoorschoonmaak en glazenwassen laten zich goed combineren. U heeft dan één aanspreekpunt en één factuur. Wij stemmen de planning op elkaar af zodat u er zelf geen omkijken naar heeft." },
  { question: "In welk gebied zijn jullie actief?", answer: "Wij werken vanuit Buren en rijden door de hele regio. Denk aan Tiel, Culemborg, Geldermalsen en Elst. Niet zeker of wij bij u in de buurt komen? Bel gerust." },
];
---

<Layout title="Schoonmaakdiensten Betuwe | John's Schoonmaakbedrijf" description="Kantoorschoonmaak, glazenwassen en opleveringsschoonmaak in de Betuwe. VCA-gecertificeerde vaste teams. Bekijk onze diensten en vraag een offerte aan.">
  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-surface-blue" style="padding-top: 64px; padding-bottom: 48px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">
        <nav class="text-[13px] text-text-muted mb-6" aria-label="Breadcrumb">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span class="text-text">Diensten</span>
        </nav>
        <h1>Schoonmaakdiensten in de Betuwe</h1>
        <p class="text-text-muted text-[17px] mt-4 max-w-2xl" style="line-height: 1.7;">John's Schoonmaakbedrijf verzorgt schoonmaakdiensten voor bedrijven in de Betuwe: kantoorschoonmaak, glazenwassen, opleveringsschoonmaak, zonnepanelen reinigen, dakgoten leegmaken en gevelreiniging. Vaste, VCA-gecertificeerde teams voor elk type klus — sinds 2007, met een persoonlijke benadering.</p>
      </div>
    </section>

    <!-- Intro -->
    <section class="bg-bg" style="padding-top: 64px; padding-bottom: 16px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">
        <p class="text-text-muted text-[17px] max-w-2xl" style="line-height: 1.7;">Hieronder vindt u een overzicht van wat wij doen. Elke dienst heeft een eigen pagina met meer details over aanpak, werkwijze en veelgestelde vragen.</p>
        <p class="text-text-muted text-[17px] mt-4 max-w-2xl" style="line-height: 1.7;">Heeft u een vraag of wilt u meteen een offerte? Neem gerust <a href="/contact/" class="text-primary hover:underline font-medium">contact</a> op.</p>
      </div>
    </section>

    <!-- Service cards: equal 3-column grid (NOT homepage's asymmetric 5fr/3fr) -->
    <section class="bg-bg" style="padding-top: 48px; padding-bottom: 80px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">
        <div class="stagger-container grid grid-cols-1 md:grid-cols-3 gap-6">

          <!-- Kantoorschoonmaak -->
          <a href="/diensten/kantoorschoonmaak/" class="scroll-fade-up card-lift bg-bg rounded-lg border border-border shadow-card p-8 flex flex-col" style="border-radius: var(--radius-lg);">
            <div class="w-12 h-12 rounded-md flex items-center justify-center mb-5" style="border-radius: var(--radius-md); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <h3 class="text-[20px] font-bold text-text mb-3">Kantoorschoonmaak</h3>
            <p class="text-[15px] text-text-muted leading-relaxed mb-6 flex-grow">Regelmatige reiniging van uw kantoor op een ritme dat bij u past. Vaste teams en een vast contactpersoon, in overleg met u als klant.</p>
            <span class="text-primary text-[15px] font-semibold inline-flex items-center gap-1.5 transition-all duration-200">
              Meer over kantoorschoonmaak
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>

          <!-- Glazenwassen -->
          <a href="/diensten/glazenwassen/" class="scroll-fade-up card-lift bg-bg rounded-lg border border-border shadow-card p-8 flex flex-col" style="border-radius: var(--radius-lg);">
            <div class="w-12 h-12 rounded-md flex items-center justify-center mb-5" style="border-radius: var(--radius-md); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"/></svg>
            </div>
            <h3 class="text-[20px] font-bold text-text mb-3">Glazenwassen</h3>
            <p class="text-[15px] text-text-muted leading-relaxed mb-6 flex-grow">Professioneel ramen wassen tot 12 meter hoogte. Binnen en buiten, inclusief kozijnen. Met het Telewash-systeem: streeploos en zonder chemie.</p>
            <span class="text-primary text-[15px] font-semibold inline-flex items-center gap-1.5 transition-all duration-200">
              Meer over glazenwassen
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>

          <!-- Bouw-oplevering -->
          <a href="/diensten/bouw-oplevering/" class="scroll-fade-up card-lift bg-bg rounded-lg border border-border shadow-card p-8 flex flex-col" style="border-radius: var(--radius-lg);">
            <div class="w-12 h-12 rounded-md flex items-center justify-center mb-5" style="border-radius: var(--radius-md); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            </div>
            <h3 class="text-[20px] font-bold text-text mb-3">Bouw-oplevering</h3>
            <p class="text-[15px] text-text-muted leading-relaxed mb-6 flex-grow">Grondige eindreiniging na verbouwing of nieuwbouw. Stof, bouwresten en cementresten verwijderd.</p>
            <span class="text-primary text-[15px] font-semibold inline-flex items-center gap-1.5 transition-all duration-200">
              Meer over opleveringsschoonmaak
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>
        </div>

        <!-- Additional services: 3-column, simpler style for visual variety -->
        <h3 class="scroll-fade-up font-head text-[16px] font-bold text-text-muted uppercase tracking-[1.5px] mt-12 mb-6">Overige diensten</h3>
        <div class="stagger-container grid grid-cols-1 md:grid-cols-3 gap-5">
          <a id="zonnepanelen" href="/diensten/zonnepanelen/" class="card-lift flex items-center gap-4 p-5 bg-bg rounded-lg border border-border transition-all" style="border-radius: var(--radius-lg);">
            <div class="w-10 h-10 rounded-md bg-primary-100 flex items-center justify-center shrink-0" style="border-radius: var(--radius-md);">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            </div>
            <div>
              <p class="text-[15px] font-semibold text-text">Zonnepanelen reinigen</p>
              <p class="text-[13px] text-text-muted">Met osmosewater, veilig vanaf de grond.</p>
            </div>
          </a>
          <a id="dakgoten" href="/diensten/dakgoten/" class="card-lift flex items-center gap-4 p-5 bg-bg rounded-lg border border-border transition-all" style="border-radius: var(--radius-lg);">
            <div class="w-10 h-10 rounded-md bg-primary-100 flex items-center justify-center shrink-0" style="border-radius: var(--radius-md);">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 4h18M3 4v16h18V4M7 8v8m5-8v8m5-8v8"/></svg>
            </div>
            <div>
              <p class="text-[15px] font-semibold text-text">Dakgoten leegmaken</p>
              <p class="text-[13px] text-text-muted">Voorkom verstoppingen en waterschade.</p>
            </div>
          </a>
          <a id="gevelreiniging" href="/diensten/gevelreiniging/" class="card-lift flex items-center gap-4 p-5 bg-bg rounded-lg border border-border transition-all" style="border-radius: var(--radius-lg);">
            <div class="w-10 h-10 rounded-md bg-primary-100 flex items-center justify-center shrink-0" style="border-radius: var(--radius-md);">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6z"/></svg>
            </div>
            <div>
              <p class="text-[15px] font-semibold text-text">Gevelreiniging</p>
              <p class="text-[13px] text-text-muted">Houtwerk, kunststof en trespa professioneel gereinigd.</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ section -->
    <section class="bg-surface" style="padding-top: 64px; padding-bottom: 64px;">
      <div class="max-w-3xl mx-auto px-5 md:px-10">
        <h2 class="scroll-fade-up text-center mb-8">Veelgestelde vragen</h2>
        <div class="space-y-4">
          <details class="faq-item group" open>
            <summary class="faq-summary">Welke schoonmaakdiensten bieden jullie aan?</summary>
            <div class="faq-body"><p>Kantoorschoonmaak, glazenwassen, opleveringsschoonmaak, zonnepanelen reinigen, dakgoten leegmaken en gevelreiniging. Van regulier onderhoud tot eenmalige klussen.</p></div>
          </details>
          <details class="faq-item group">
            <summary class="faq-summary">Kunnen meerdere diensten gecombineerd worden?</summary>
            <div class="faq-body"><p>Ja, dat kan. Kantoorschoonmaak en glazenwassen laten zich goed combineren. U heeft dan één aanspreekpunt en één factuur. Wij stemmen de planning op elkaar af zodat u er zelf geen omkijken naar heeft.</p></div>
          </details>
          <details class="faq-item group">
            <summary class="faq-summary">In welk gebied zijn jullie actief?</summary>
            <div class="faq-body"><p>Wij werken vanuit Buren en rijden door de hele regio. Denk aan Tiel, Culemborg, Geldermalsen en Elst. Niet zeker of wij bij u in de buurt komen? Bel gerust.</p></div>
          </details>
        </div>
      </div>
    </section>

    <CtaSection
      heading="Niet zeker welke dienst u nodig heeft?"
      subtext="Bel gerust, dan denken wij vrijblijvend met u mee."
      primaryText="Offerte aanvragen"
      primaryHref="/contact/"
    />
  </main>
  <Footer />
  <SchemaFAQ faqs={faqs} />
</Layout>

<style>
  .faq-item { border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; transition: box-shadow 0.2s; }
  .faq-item[open] { box-shadow: var(--shadow-card); }
  .faq-summary { padding: 20px 24px; font-family: var(--font-head); font-size: 16px; font-weight: 600; color: var(--color-text); cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; gap: 16px; transition: background 0.15s; }
  .faq-summary:hover { background: var(--color-surface); }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary::after { content: '+'; font-size: 20px; font-weight: 300; color: var(--color-primary); flex-shrink: 0; }
  .faq-item[open] .faq-summary::after { content: '\2212'; }
  .faq-body { padding: 0 24px 20px; font-size: 15px; color: var(--color-text-muted); line-height: 1.75; }
</style>
