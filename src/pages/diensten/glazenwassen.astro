---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CtaSection from "../../components/CtaSection.astro";
import SchemaService from "../../components/seo/SchemaService.astro";
import SchemaFAQ from "../../components/seo/SchemaFAQ.astro";

const faqs = [
  { question: "Hoe vaak moeten de ramen van een bedrijfspand gewassen worden?", answer: "Dat verschilt per situatie. Panden aan een drukke weg of in een industriegebied worden sneller vies. Per kwartaal is gebruikelijk voor kantoorpanden, maar je kiest zelf het ritme. Horecazaken en winkels laten het vaker doen, vaak maandelijks. We denken graag even mee over wat past bij jouw pand." },
  { question: "Wat is het Telewash-systeem precies?", answer: "Telewash werkt met osmosewater: gezuiverd water zonder mineralen. We pompen dat via telescoopstelen langs de ramen. Omdat het water puur is, droogt het streeploos op. Geen zeep, geen vlekken. En het resultaat is beter dan traditionele methodes met reinigingsmiddel." },
  { question: "Kunnen glazenwassen en kantoorschoonmaak gecombineerd worden?", answer: "Ja, dat kan. Je hebt dan één aanspreekpunt en één factuur. En als we toch in de buurt zijn voor glazenwassen, kunnen we meteen de kantoorschoonmaak meenemen." },
  { question: "Tot welke hoogte wassen jullie ramen?", answer: "Met het Telewash-systeem wassen we ramen tot 12 meter hoogte. Dat zijn zo'n 4 verdiepingen. Zonder steiger of hoogwerker. Heb je hogere ramen? Neem dan even contact op, dan bekijken we de mogelijkheden." },
];
---

<Layout title="Glazenwassen Betuwe · Tot 12 meter | John's Schoonmaakbedrijf" description="Professioneel glazenwassen in de Betuwe. Tot 12 meter hoogte met Telewash-systeem. Binnen en buiten, inclusief kozijnen. Vraag een offerte aan.">
  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-bg relative overflow-hidden" style="padding-top: 64px; padding-bottom: 56px;">
      <div class="absolute pointer-events-none" style="top: -80px; left: -80px; width: 350px; height: 350px; border-radius: 50%; background: var(--color-primary-light); opacity: 0.04; filter: blur(60px);" aria-hidden="true"></div>
      <div class="max-w-[1360px] mx-auto px-5 md:px-10 relative z-10">
        <nav class="text-[13px] text-text-muted mb-6" aria-label="Breadcrumb">
          <a href="/" class="hover:text-primary transition-colors">Home</a><span class="mx-2">/</span>
          <a href="/diensten/" class="hover:text-primary transition-colors">Diensten</a><span class="mx-2">/</span>
          <span class="text-text">Glazenwassen</span>
        </nav>
        <div class="max-w-2xl">
          <h1 class="mb-5">Glazenwassen voor bedrijven in de Betuwe</h1>
          <p class="text-text-muted text-[17px]" style="line-height: 1.7;">Glazenwassen voor je bedrijfspand in de Betuwe of Rivierenland? John's Schoonmaakbedrijf wast ramen tot 12 meter hoogte met het Telewash-systeem. Binnen en buiten, inclusief kozijnen en dorpels. Maandelijks, per kwartaal of gewoon wanneer het nodig is. VCA-gecertificeerde glazenwassers, streeploos resultaat.</p>
        </div>
      </div>
    </section>

    <!-- Description -->
    <section class="bg-surface" style="padding-top: 64px; padding-bottom: 80px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">
        <div class="max-w-3xl scroll-fade-up">
          <h2 class="mb-5">Professioneel glazenwassen voor bedrijfspanden</h2>
          <div class="text-[16px] text-text-muted space-y-5" style="line-height: 1.75;">
            <p>We wassen de ramen van je kantoorpand, buitenkant en binnenkant. Kozijnen en dorpels doen we er standaard bij, dus je hele gevel ziet er weer verzorgd uit.</p>
            <p>We werken met het Telewash-systeem: osmosewater zonder mineralen. Geen zeep, geen chemie, geen strepen. Het water droogt vanzelf op zonder vlekken.</p>
            <p>Voor hogere verdiepingen gebruiken we telescoopstelen tot 12 meter. Geen steiger of hoogwerker nodig. Dat scheelt kosten en overlast. Van kantoorpanden tot scholen: we wassen overal.</p>
            <p>Je kiest zelf het ritme. Maandelijks voor panden aan een drukke weg, per kwartaal voor een gemiddeld kantoor, of op afroep als je vindt dat het tijd wordt. Jij belt, wij plannen.</p>
          </div>
        </div>
        <div class="scroll-fade-up mt-10 rounded-lg overflow-hidden" style="border-radius: var(--radius-lg); aspect-ratio: 16/7;">
          <img src="/fotos/women-cleaning-vensterbank-office.png" alt="Professioneel glazenwassen en kozijnen reinigen" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- Benefits: icon list (different layout from kantoorschoonmaak's 2x2 grid) -->
    <section class="bg-bg" style="padding-top: 72px; padding-bottom: 72px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">
        <h2 class="scroll-fade-up mb-8">Waarom kiezen voor onze glazenwassers?</h2>
        <div class="stagger-container max-w-3xl space-y-6">
          <div class="scroll-fade-up flex gap-5 items-start">
            <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center shrink-0 font-head font-bold text-[16px]">1</div>
            <div><h3 class="text-[18px] font-bold text-text mb-1">Telewash: streeploos zonder chemie</h3><p class="text-[15px] text-text-muted leading-relaxed">Osmosewater laat geen kalkresten of strepen achter. Beter voor de ramen, beter voor het milieu. En het resultaat? Gewoon schoner dan met traditionele methodes.</p></div>
          </div>
          <div class="scroll-fade-up flex gap-5 items-start">
            <div class="w-10 h-10 rounded-full bg-primary-light text-white flex items-center justify-center shrink-0 font-head font-bold text-[16px]">2</div>
            <div><h3 class="text-[18px] font-bold text-text mb-1">Tot 12 meter hoogte zonder steiger</h3><p class="text-[15px] text-text-muted leading-relaxed">Telescoopstelen met zuiver water reiken tot de vierde verdieping. Geen dure hoogwerker, geen bouwverkeer op de parkeerplaats. Praktisch en zonder overlast.</p></div>
          </div>
          <div class="scroll-fade-up flex gap-5 items-start">
            <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center shrink-0 font-head font-bold text-[16px]">3</div>
            <div><h3 class="text-[18px] font-bold text-text mb-1">Combineer met kantoorschoonmaak</h3><p class="text-[15px] text-text-muted leading-relaxed">Al klant voor <a href="/diensten/kantoorschoonmaak/" class="text-primary hover:underline">kantoorschoonmaak</a>? Dan regelt hetzelfde team ook je ramen. Eén factuur, één aanspreekpunt. Lekker makkelijk.</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Process: vertical timeline (different from kantoorschoonmaak's horizontal steps) -->
    <section class="bg-surface-blue" style="padding-top: 72px; padding-bottom: 80px;">
      <div class="max-w-3xl mx-auto px-5 md:px-10">
        <h2 class="scroll-fade-up text-center mb-10">Hoe werkt het?</h2>
        <div class="stagger-container space-y-8">
          <div class="scroll-fade-up flex gap-5"><span class="inline-block text-[12px] font-semibold text-primary bg-primary-100 border border-sky-200 px-3 py-1 rounded-full h-fit shrink-0">Stap 1</span><div><h3 class="text-[17px] font-bold text-text mb-1">Offerte</h3><p class="text-[14px] text-text-muted leading-relaxed">Neem even contact op. We bekijken je pand, tellen de ramen en geven een heldere prijs. Vrijblijvend, uiteraard.</p></div></div>
          <div class="scroll-fade-up flex gap-5"><span class="inline-block text-[12px] font-semibold text-primary bg-primary-100 border border-sky-200 px-3 py-1 rounded-full h-fit shrink-0">Stap 2</span><div><h3 class="text-[17px] font-bold text-text mb-1">Planning</h3><p class="text-[14px] text-text-muted leading-relaxed">Je kiest de frequentie: maandelijks, per kwartaal of op afroep. Wij plannen het in en je hoeft er verder niet over na te denken.</p></div></div>
          <div class="scroll-fade-up flex gap-5"><span class="inline-block text-[12px] font-semibold text-primary bg-primary-100 border border-sky-200 px-3 py-1 rounded-full h-fit shrink-0">Stap 3</span><div><h3 class="text-[17px] font-bold text-text mb-1">Uitvoering</h3><p class="text-[14px] text-text-muted leading-relaxed">Je vaste glazenwassers komen op de afgesproken dag. Binnen en buiten, kozijnen erbij. Klaar terwijl jij gewoon doorwerkt.</p></div></div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-bg" style="padding-top: 64px; padding-bottom: 64px;">
      <div class="max-w-3xl mx-auto px-5 md:px-10">
        <h2 class="scroll-fade-up text-center mb-8">Veelgestelde vragen over glazenwassen</h2>
        <div class="space-y-4">
          <details class="faq-item"><summary class="faq-summary">Hoe vaak moeten de ramen van een bedrijfspand gewassen worden?</summary><div class="faq-body"><p>Dat verschilt per situatie. Panden aan een drukke weg of in een industriegebied worden sneller vies. Per kwartaal is gebruikelijk voor kantoorpanden, maar je kiest zelf het ritme. Horecazaken en winkels laten het vaker doen, vaak maandelijks. We denken graag even mee over wat past bij jouw pand.</p></div></details>
          <details class="faq-item"><summary class="faq-summary">Wat is het Telewash-systeem precies?</summary><div class="faq-body"><p>Telewash werkt met osmosewater: gezuiverd water zonder mineralen. We pompen dat via telescoopstelen langs de ramen. Omdat het water puur is, droogt het streeploos op. Geen zeep, geen vlekken. En het resultaat is beter dan traditionele methodes met reinigingsmiddel.</p></div></details>
          <details class="faq-item"><summary class="faq-summary">Kunnen glazenwassen en kantoorschoonmaak gecombineerd worden?</summary><div class="faq-body"><p>Ja, dat kan. Je hebt dan één aanspreekpunt en één factuur. En als we toch in de buurt zijn voor glazenwassen, kunnen we meteen de kantoorschoonmaak meenemen.</p></div></details>
          <details class="faq-item"><summary class="faq-summary">Tot welke hoogte wassen jullie ramen?</summary><div class="faq-body"><p>Met het Telewash-systeem wassen we ramen tot 12 meter hoogte. Dat zijn zo'n 4 verdiepingen. Zonder steiger of hoogwerker. Heb je hogere ramen? Neem dan even <a href="/contact/" class="text-primary hover:underline">contact</a> op, dan bekijken we de mogelijkheden.</p></div></details>
        </div>
      </div>
    </section>

    <!-- Cross-links -->
    <section class="bg-surface" style="padding-top: 48px; padding-bottom: 48px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">
        <h3 class="font-head text-[16px] font-bold text-text-muted uppercase tracking-[1.5px] mb-5">Ook interessant</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <a href="/diensten/kantoorschoonmaak/" class="card-lift flex items-center gap-4 p-5 bg-bg rounded-lg border border-border transition-all" style="border-radius: var(--radius-lg);">
            <div class="w-10 h-10 rounded-md bg-primary-100 flex items-center justify-center shrink-0" style="border-radius: var(--radius-md);"><svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg></div>
            <div><p class="text-[15px] font-semibold text-text">Kantoorschoonmaak</p><p class="text-[13px] text-text-muted">Combineer met kantoorschoonmaak voor één team en één factuur.</p></div>
          </a>
          <a href="/over-ons/" class="card-lift flex items-center gap-4 p-5 bg-bg rounded-lg border border-border transition-all" style="border-radius: var(--radius-lg);">
            <div class="w-10 h-10 rounded-md bg-primary-100 flex items-center justify-center shrink-0" style="border-radius: var(--radius-md);"><svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg></div>
            <div><p class="text-[15px] font-semibold text-text">Over John's Schoonmaakbedrijf</p><p class="text-[13px] text-text-muted">Meer over ons team en werkwijze.</p></div>
          </a>
        </div>
      </div>
    </section>

    <CtaSection heading="Ramen die wel weer eens gewassen mogen worden?" subtext="Vraag een vrijblijvende offerte aan voor glazenwassen. We komen even kijken en je weet snel waar je aan toe bent." primaryText="Offerte aanvragen" primaryHref="/contact/?dienst=glazenwassen" />
  </main>
  <Footer />
  <SchemaService
    name="Glazenwassen"
    description="Professioneel glazenwassen in de Betuwe. Tot 12 meter hoogte met Telewash-systeem. Binnen en buiten, inclusief kozijnen en dorpels."
    url="/diensten/glazenwassen/"
  />
  <SchemaFAQ faqs={faqs} />
</Layout>

<style>
  .faq-item { border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; transition: box-shadow 0.2s; }
  .faq-item[open] { box-shadow: var(--shadow-card); }
  .faq-summary { padding: 20px 24px; font-family: var(--font-head); font-size: 16px; font-weight: 600; color: var(--color-text); cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; gap: 16px; transition: background 0.15s; }
  .faq-summary:hover { background: var(--color-surface); }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary::after { content: '+'; font-size: 20px; font-weight: 300; color: var(--color-primary); flex-shrink: 0; }
  .faq-item[open] .faq-summary::after { content: '\2212'; }
  .faq-body { padding: 0 24px 20px; font-size: 15px; color: var(--color-text-muted); line-height: 1.75; }
</style>
