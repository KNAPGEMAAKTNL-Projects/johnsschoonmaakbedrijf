---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CtaSection from "../../components/CtaSection.astro";
import SchemaService from "../../components/seo/SchemaService.astro";
import SchemaFAQ from "../../components/seo/SchemaFAQ.astro";

const faqs = [
  { question: "Hoe vaak moeten dakgoten worden leeggemaakt?", answer: "Minstens een keer per jaar, liefst in het najaar na de bladval. Staat je pand tussen bomen? Dan is twee keer per jaar aan te raden: najaar en voorjaar." },
  { question: "Kan ik mijn dakgoten zelf leegmaken?", answer: "Dat kan, maar het betekent op een ladder klimmen en vies werk doen. Niet zonder risico, zeker niet bij hogere panden. Wij hebben het juiste gereedschap en de ervaring om het snel en veilig te doen." },
  { question: "Doen jullie ook reparaties aan dakgoten?", answer: "Kleine reparaties zoals een lekkende naad of een loshangende beugel pakken we mee. Voor grotere reparaties verwijzen we je eerlijk door naar een dakdekker." },
];
---

<Layout title="Dakgoten leegmaken | John's Schoonmaakbedrijf" description="Dakgoten leegmaken en controleren op verstoppingen. Blad, mos en vuil verwijderd. Jaarlijks onderhoud door vakmensen. Vraag een vrijblijvende offerte aan.">
  <Header />
  <main>
    <!-- Hero -->
    <section class="bg-bg relative overflow-hidden" style="padding-top: 64px; padding-bottom: 56px;">
      <div class="absolute pointer-events-none" style="top: -60px; left: -40px; width: 320px; height: 320px; border-radius: 50%; background: var(--color-primary-light); opacity: 0.04; filter: blur(55px);" aria-hidden="true"></div>
      <div class="max-w-[1360px] mx-auto px-5 md:px-10 relative z-10">
        <nav class="text-[13px] text-text-muted mb-6" aria-label="Breadcrumb">
          <a href="/" class="hover:text-primary transition-colors">Home</a><span class="mx-2">/</span>
          <a href="/diensten/" class="hover:text-primary transition-colors">Diensten</a><span class="mx-2">/</span>
          <span class="text-text">Dakgoten leegmaken</span>
        </nav>
        <div class="max-w-2xl">
          <h1 class="mb-5">Dakgoten leegmaken in de Betuwe</h1>
          <p class="text-text-muted text-[17px]" style="line-height: 1.7;">John's Schoonmaakbedrijf maakt je dakgoten leeg en controleert op verstoppingen. Blad, mos en vuil verwijderd, afvoeren gecontroleerd. We raden het minstens een keer per jaar aan, liefst in het najaar.</p>
        </div>
      </div>
    </section>

    <!-- Description -->
    <section class="bg-surface" style="padding-top: 64px; padding-bottom: 80px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">
        <div class="max-w-3xl scroll-fade-up">
          <h2 class="mb-5">Voorkom wateroverlast</h2>
          <div class="text-[16px] text-text-muted space-y-5" style="line-height: 1.75;">
            <p>Een verstopte dakgoot merk je pas als het te laat is. Water loopt over, langs de gevel, in de spouw. Vochtplekken binnen, schimmel achter het behang. Vervelend en duur.</p>
            <p>Het is zo'n klusje dat je steeds uitstelt. Begrijpelijk, want je moet op een ladder, het is nat, het is vies. Wij pakken het gewoon voor je op. Dakgoten leeghalen, afvoeren controleren, alles weer schoon. In de meeste gevallen zijn we binnen een uur klaar.</p>
            <p>We raden aan om je dakgoten minstens een keer per jaar te laten leeghalen. In het najaar, als de bomen kaal worden. Heb je veel bomen om je pand heen? Dan is twee keer per jaar verstandiger: eind november en nog eens in het voorjaar.</p>
            <p>Staat je pand tussen de boomgaarden? Blad, bloesem en appels in de goot: we komen het regelmatig tegen. Neem gerust contact op, dan plannen we het in.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Benefits: 3-col cards (like bouw-oplevering) -->
    <section class="bg-bg" style="padding-top: 72px; padding-bottom: 72px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">
        <h2 class="scroll-fade-up mb-8">Waarom laten doen?</h2>
        <div class="stagger-container grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="card-lift bg-surface rounded-lg border border-border p-7 text-center" style="border-radius: var(--radius-lg);">
            <div class="w-12 h-12 mx-auto rounded-full bg-primary text-white flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <h3 class="text-[18px] font-bold text-text mb-2">Veilig en professioneel</h3>
            <p class="text-[14px] text-text-muted leading-relaxed">Geen ladder meer tegen de gevel, geen emmer op het dak. Wij hebben het juiste materiaal en de ervaring. Jij houdt je voeten op de grond.</p>
          </div>
          <div class="card-lift bg-surface rounded-lg border border-border p-7 text-center" style="border-radius: var(--radius-lg);">
            <div class="w-12 h-12 mx-auto rounded-full bg-primary-light text-white flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
            <h3 class="text-[18px] font-bold text-text mb-2">Controle op afvoeren en lekkages</h3>
            <p class="text-[14px] text-text-muted leading-relaxed">We maken niet alleen de goot leeg, we controleren ook of het regenwater goed wegloopt. Een klein probleem nu is goedkoper dan een groot probleem straks.</p>
          </div>
          <div class="card-lift bg-surface rounded-lg border border-border p-7 text-center" style="border-radius: var(--radius-lg);">
            <div class="w-12 h-12 mx-auto rounded-full bg-primary text-white flex items-center justify-center mb-4">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h3 class="text-[18px] font-bold text-text mb-2">Alles in een afspraak</h3>
            <p class="text-[14px] text-text-muted leading-relaxed">We kunnen in dezelfde afspraak ook je <a href="/diensten/zonnepanelen/" class="text-primary hover:underline">zonnepanelen reinigen</a> of <a href="/diensten/glazenwassen/" class="text-primary hover:underline">ramen wassen</a>. Dat scheelt je een extra afspraak en is vaak voordeliger.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Process: vertical badge-steps -->
    <section class="bg-surface-blue" style="padding-top: 72px; padding-bottom: 80px;">
      <div class="max-w-3xl mx-auto px-5 md:px-10">
        <h2 class="scroll-fade-up text-center mb-10">Hoe werkt het?</h2>
        <div class="stagger-container space-y-8">
          <div class="scroll-fade-up flex gap-5"><span class="inline-block text-[12px] font-semibold text-primary bg-primary-100 border border-sky-200 px-3 py-1 rounded-full h-fit shrink-0">Stap 1</span><div><h3 class="text-[17px] font-bold text-text mb-1">Even bellen of mailen</h3><p class="text-[14px] text-text-muted leading-relaxed">Vertel ons wat voor pand het is en of er bijzonderheden zijn. Plat dak, schuin dak, meerdere goten, maakt niet uit.</p></div></div>
          <div class="scroll-fade-up flex gap-5"><span class="inline-block text-[12px] font-semibold text-primary bg-primary-100 border border-sky-200 px-3 py-1 rounded-full h-fit shrink-0">Stap 2</span><div><h3 class="text-[17px] font-bold text-text mb-1">Planning</h3><p class="text-[14px] text-text-muted leading-relaxed">We komen op een moment dat jou uitkomt. Meestal lukt dat binnen een week. In het najaar is het drukker, dus plan het liefst even vooruit.</p></div></div>
          <div class="scroll-fade-up flex gap-5"><span class="inline-block text-[12px] font-semibold text-primary bg-primary-100 border border-sky-200 px-3 py-1 rounded-full h-fit shrink-0">Stap 3</span><div><h3 class="text-[17px] font-bold text-text mb-1">Klus klaar</h3><p class="text-[14px] text-text-muted leading-relaxed">Goten leeg, afvoer gecontroleerd. We nemen het vuil mee en je hoeft er verder niet over na te denken.</p></div></div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-bg" style="padding-top: 64px; padding-bottom: 64px;">
      <div class="max-w-3xl mx-auto px-5 md:px-10">
        <h2 class="scroll-fade-up text-center mb-8">Veelgestelde vragen over dakgoten leegmaken</h2>
        <div class="space-y-4">
          <details class="faq-item"><summary class="faq-summary">Hoe vaak moeten dakgoten worden leeggemaakt?</summary><div class="faq-body"><p>Minstens een keer per jaar, liefst in het najaar na de bladval. Staat je pand tussen bomen? Dan is twee keer per jaar aan te raden: najaar en voorjaar.</p></div></details>
          <details class="faq-item"><summary class="faq-summary">Kan ik mijn dakgoten zelf leegmaken?</summary><div class="faq-body"><p>Dat kan, maar het betekent op een ladder klimmen en vies werk doen. Niet zonder risico, zeker niet bij hogere panden. Wij hebben het juiste gereedschap en de ervaring om het snel en veilig te doen.</p></div></details>
          <details class="faq-item"><summary class="faq-summary">Doen jullie ook reparaties aan dakgoten?</summary><div class="faq-body"><p>Kleine reparaties zoals een lekkende naad of een loshangende beugel pakken we mee. Voor grotere reparaties verwijzen we je eerlijk door naar een dakdekker.</p></div></details>
        </div>
      </div>
    </section>

    <!-- Cross-links -->
    <section class="bg-surface" style="padding-top: 48px; padding-bottom: 48px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">
        <h3 class="font-head text-[16px] font-bold text-text-muted uppercase tracking-[1.5px] mb-5">Ook interessant</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <a href="/diensten/zonnepanelen/" class="card-lift flex items-center gap-4 p-5 bg-bg rounded-lg border border-border transition-all" style="border-radius: var(--radius-lg);">
            <div class="w-10 h-10 rounded-md bg-primary-100 flex items-center justify-center shrink-0" style="border-radius: var(--radius-md);"><svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg></div>
            <div><p class="text-[15px] font-semibold text-text">Zonnepanelen reinigen</p><p class="text-[13px] text-text-muted">Gelijk je zonnepanelen erbij?</p></div>
          </a>
          <a href="/diensten/glazenwassen/" class="card-lift flex items-center gap-4 p-5 bg-bg rounded-lg border border-border transition-all" style="border-radius: var(--radius-lg);">
            <div class="w-10 h-10 rounded-md bg-primary-100 flex items-center justify-center shrink-0" style="border-radius: var(--radius-md);"><svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"/></svg></div>
            <div><p class="text-[15px] font-semibold text-text">Glazenwassen</p><p class="text-[13px] text-text-muted">Combineer met ramen wassen.</p></div>
          </a>
        </div>
      </div>
    </section>

    <CtaSection heading="Dakgoten vol?" subtext="Neem even contact op. We plannen het snel in en je hebt er weer een jaar geen omkijken naar." primaryText="Offerte aanvragen" primaryHref="/contact/?dienst=dakgoten" />
  </main>
  <Footer />
  <SchemaService
    name="Dakgoten leegmaken"
    description="Dakgoten leegmaken en controleren op verstoppingen. Blad, mos en vuil verwijderd. Minstens 1x per jaar, liefst in het najaar."
    url="/diensten/dakgoten/"
  />
  <SchemaFAQ faqs={faqs} />
</Layout>

<style>
  .faq-item { border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; transition: box-shadow 0.2s; }
  .faq-item[open] { box-shadow: var(--shadow-card); }
  .faq-summary { padding: 20px 24px; font-family: var(--font-head); font-size: 16px; font-weight: 600; color: var(--color-text); cursor: pointer; list-style: none; display: flex; align-items: center; justify-content: space-between; gap: 16px; transition: background 0.15s; }
  .faq-summary:hover { background: var(--color-surface); }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-summary::after { content: '+'; font-size: 20px; font-weight: 300; color: var(--color-primary); flex-shrink: 0; }
  .faq-item[open] .faq-summary::after { content: '\2212'; }
  .faq-body { padding: 0 24px 20px; font-size: 15px; color: var(--color-text-muted); line-height: 1.75; }
</style>
