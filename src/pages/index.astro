---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.astro";
---

<Layout
  title="Schoonmaakbedrijf Betuwe · VCA | John's Schoonmaakbedrijf"
  description="VCA-gecertificeerd schoonmaakbedrijf in Buren. Kantoorschoonmaak, glazenwassen en opleveringsschoonmaak. Vaste teams, 9,7/10. Vraag een offerte aan."
>
  <Header />

  <main>
    <!-- ═══════════════════════════════════════════════
         SECTION 1: HERO — bg: white, pt:80 pb:64
         Grid: 58fr 42fr, gap 64px
         Effects: page-load cascade, gradient mesh, floating bob
         Decorative: blob mesh, S-curve flourish, gradient underline
         ═══════════════════════════════════════════════ -->
    <section class="bg-bg relative overflow-hidden" style="padding-top: 80px; padding-bottom: 64px;">
      <!-- Ambient blob mesh (DESIGN.md §7.1) -->
      <div class="hero-blobs absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute" style="top: -100px; left: -80px; width: 560px; height: 560px; border-radius: 50%; background: var(--color-primary); opacity: 0.055; filter: blur(90px);"></div>
        <div class="absolute" style="top: 50%; left: 25%; width: 380px; height: 380px; border-radius: 50%; background: var(--color-accent); opacity: 0.07; filter: blur(70px);"></div>
      </div>

      <div class="max-w-[1360px] mx-auto px-5 md:px-10 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-[58fr_42fr] gap-10 lg:gap-16 items-center">

          <!-- Left column: content -->
          <div>
            <!-- Eyebrow pill (DESIGN.md §5) -->
            <div class="hero-enter-1 mb-5 relative">
              <span class="inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-[2px] text-primary bg-primary-100 border border-sky-200 px-3.5 py-1.5 rounded-full">
                <span class="w-1.5 h-1.5 rounded-full bg-primary-light"></span>
                VCA-gecertificeerd · Betuwe &amp; Rivierenland
              </span>
            </div>

            <!-- H1 — NO opacity:0 (LCP safety) -->
            <h1 class="hero-enter-1 mb-6">
              Schone kantoren,<br>
              <span class="hl">betrouwbare teams</span>
            </h1>

            <!-- Hero subtext -->
            <p class="hero-enter-2 text-[17px] text-text-muted leading-relaxed mb-6 max-w-lg" style="line-height: 1.7;">
              Kantoorschoonmaak voor bedrijven in de Betuwe. Vaste medewerkers, heldere tarieven en een vast aanspreekpunt. Al meer dan 15 jaar.
            </p>

            <!-- AI SEO direct answer paragraph -->
            <p class="hero-enter-2 text-[15px] text-text-muted leading-relaxed mb-8 max-w-lg">
              John's Schoonmaakbedrijf uit Buren verzorgt kantoorschoonmaak, glazenwassen en opleveringsschoonmaak. Al sinds 2007 werken we met vaste schoonmaakteams. Kantoren, scholen, bedrijfspanden: overal dezelfde vertrouwde gezichten. VCA-gecertificeerd, met een 4,5 uit 5 op Google.
            </p>

            <!-- CTA buttons -->
            <div class="hero-enter-3 flex flex-col sm:flex-row gap-3 mb-8">
              <a href="#contact" class="bg-primary text-white font-head text-[15px] font-semibold px-7 py-3.5 rounded-full hover:bg-navy hover:shadow-btn hover:-translate-y-px transition-all duration-200 inline-flex items-center justify-center gap-2 min-w-[200px]">
                Vrijblijvende offerte aanvragen
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>
              <a href="tel:0623545276" class="border-2 border-primary text-primary font-head text-[15px] font-semibold px-7 py-[13px] rounded-full hover:bg-primary hover:text-white transition-all duration-200 inline-flex items-center justify-center gap-2 min-w-[200px]">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                Bel 06 23545276
              </a>
            </div>

            <!-- Trust strip -->
            <div class="hero-enter-4 flex flex-wrap gap-x-6 gap-y-2 text-[13px] text-text-muted">
              <span class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                VCA-gecertificeerd
              </span>
              <a href="https://www.google.com/maps/search/John's+Schoonmaakbedrijf+Buren" target="_blank" rel="noopener" class="flex items-center gap-1.5 hover:text-primary transition-colors">
                <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                4,5/5 · 15 Google reviews
              </a>
              <span class="flex items-center gap-1.5">
                <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                Sinds 2007
              </span>
            </div>
          </div>

          <!-- Right column: hero image area with floating elements -->
          <div class="relative hidden lg:block">
            <!-- Hero image placeholder -->
            <div class="relative rounded-xl overflow-hidden" style="border-radius: var(--radius-xl); aspect-ratio: 4/3;">
              <img src="/fotos/new-crew-pic.jpeg" alt="Het team van John's Schoonmaakbedrijf aan het werk" class="absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" />
            </div>

            <!-- Float card: bottom-left (DESIGN.md §7.4) -->
            <div class="float-bob absolute -bottom-5 -left-7 bg-bg rounded-lg p-[18px_22px] shadow-[0_8px_32px_rgba(3,105,161,0.18)] border border-border min-w-[160px] z-10" style="border-radius: var(--radius-lg);">
              <div class="font-head text-[28px] font-bold text-primary leading-none">15+</div>
              <div class="text-[13px] text-text-muted mt-1">jaar ervaring</div>
            </div>

            <!-- Float badge: top-right (DESIGN.md §7.4) -->
            <div class="float-bob absolute top-5 -right-5 bg-accent rounded-md px-3.5 py-2.5 shadow-[0_6px_20px_rgba(234,179,8,0.35)] z-10 flex items-center gap-2" style="border-radius: var(--radius-md); animation-delay: 1s;">
              <svg class="w-4 h-4 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-[12px] font-bold text-navy">Morgen beginnen?</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Wave divider: hero → USP (DESIGN.md §7.2) -->
    <div aria-hidden="true">
      <svg viewBox="0 0 1440 64" preserveAspectRatio="none" style="height: 64px; display: block; width: 100%;">
        <path d="M0,32 C240,64 480,0 720,32 C960,64 1200,0 1440,32 L1440,64 L0,64 Z" fill="var(--color-surface-blue)" />
      </svg>
    </div>

    <!-- ═══════════════════════════════════════════════
         SECTION 2: USP STRIP — bg: surface-blue, py:48
         Grid: repeat(3, 1fr), border-right separators
         Effects: stagger reveal
         Decorative: gradient icon backgrounds (BUILD-PLAN craft #2)
         ═══════════════════════════════════════════════ -->
    <section class="bg-surface-blue" style="padding: 48px 0;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">
        <div class="stagger-container grid grid-cols-1 md:grid-cols-3">

          <!-- USP 1 -->
          <div class="usp-item flex gap-4 items-start p-6 md:pr-8 md:border-r md:border-primary/10">
            <div class="shrink-0 w-12 h-12 rounded-md flex items-center justify-center" style="border-radius: var(--radius-md); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-[18px] font-bold text-text mb-1">Altijd dezelfde mensen</h3>
              <p class="text-[14px] text-text-muted leading-relaxed">Vaste schoonmaakteams op je locatie, dus je hebt altijd met dezelfde mensen te maken. We controleren ons eigen werk regelmatig en zijn altijd bereikbaar.</p>
            </div>
          </div>

          <!-- USP 2 -->
          <div class="usp-item flex gap-4 items-start p-6 md:px-8 md:border-r md:border-primary/10">
            <div class="shrink-0 w-12 h-12 rounded-md flex items-center justify-center" style="border-radius: var(--radius-md); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-[18px] font-bold text-text mb-1">Makkelijk en snel begroot</h3>
              <p class="text-[14px] text-text-muted leading-relaxed">Offerte binnen 24 uur na locatiebezoek. Je weet vooraf precies wat het kost.</p>
            </div>
          </div>

          <!-- USP 3 -->
          <div class="usp-item flex gap-4 items-start p-6 md:pl-8">
            <div class="shrink-0 w-12 h-12 rounded-md flex items-center justify-center" style="border-radius: var(--radius-md); background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-[18px] font-bold text-text mb-1">Veilig en milieuvriendelijk</h3>
              <p class="text-[14px] text-text-muted leading-relaxed">VCA-opgeleide medewerkers en milieuvriendelijke schoonmaakproducten. Veilig voor je personeel en de werkplek.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         SECTION 3: SERVICES — bg: surface, pt:80 pb:96
         Grid: 5fr 3fr, anchor spans 2 rows (editorial asymmetric)
         Effects: fade-up, card lift hover
         Decorative: anchor bg circle (DESIGN.md §7.9)
         ═══════════════════════════════════════════════ -->
    <section class="bg-surface" style="padding-top: 80px; padding-bottom: 96px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">

        <!-- Section header -->
        <div class="scroll-fade-up flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
          <div>
            <span class="kicker">ONZE DIENSTEN</span>
            <h2>Waar kunnen we je mee helpen?</h2>
            <p class="text-text-muted text-[17px] mt-3 max-w-lg">Van dagelijkse kantoorschoonmaak tot glazenwassen op hoogte. Alles onder één dak.</p>
          </div>
          <a href="/diensten/" class="border-2 border-primary text-primary font-head text-[15px] font-semibold px-7 py-[13px] rounded-full hover:bg-primary hover:text-white transition-all duration-200 inline-flex items-center gap-2 self-start shrink-0 min-w-[200px] justify-center">
            Alle diensten bekijken
          </a>
        </div>

        <!-- Services grid: 5fr 3fr, anchor spans 2 rows -->
        <div class="grid grid-cols-1 lg:grid-cols-[5fr_3fr] gap-5">

          <!-- Anchor card: Kantoorschoonmaak (dark, spans 2 rows) -->
          <div class="scroll-fade-up bg-navy rounded-xl relative overflow-hidden lg:row-span-2 flex flex-col justify-between" style="border-radius: var(--radius-xl); padding: 44px 44px 40px; min-height: 420px;">
            <!-- Anchor bg circle (DESIGN.md §7.9) -->
            <div class="absolute pointer-events-none" style="top: -80px; right: -80px; width: 280px; height: 280px; border-radius: 50%; background: var(--color-primary); opacity: 0.18;" aria-hidden="true"></div>

            <div class="relative z-10">
              <!-- Service tag -->
              <span class="inline-block text-[10px] font-bold uppercase tracking-[2px] text-accent mb-4 px-3 py-1 rounded-full" style="background: rgba(250,204,21,0.15); border: 1px solid rgba(250,204,21,0.3);">
                MEEST GEVRAAGD
              </span>
              <h3 class="font-head text-[30px] font-extrabold text-white mb-4 leading-tight" style="letter-spacing: -0.02em;">Kantoorschoonmaak op maat</h3>
              <p class="text-white/70 text-[15px] leading-relaxed mb-6">
                Regelmatige reiniging van je kantoorruimtes, van dagelijks tot maandelijks. Vaste teams die je kent en die weten hoe jouw pand eruitziet.
              </p>
              <ul class="space-y-2.5 mb-8">
                <li class="flex items-center gap-2.5 text-white/80 text-[14px]">
                  <svg class="w-4 h-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  Vaste medewerkers, vaste dag
                </li>
                <li class="flex items-center gap-2.5 text-white/80 text-[14px]">
                  <svg class="w-4 h-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  We checken ons eigen werk
                </li>
                <li class="flex items-center gap-2.5 text-white/80 text-[14px]">
                  <svg class="w-4 h-4 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  Rechtstreeks contact met John
                </li>
              </ul>
            </div>
            <a href="#contact" class="relative z-10 bg-accent text-navy font-head text-[13px] font-bold px-5 py-2.5 rounded-full hover:bg-accent-dark hover:-translate-y-px transition-all duration-200 inline-flex items-center gap-2 self-start" style="box-shadow: 0 6px 20px rgba(234,179,8,0.4);">
              Offerte aanvragen
            </a>
          </div>

          <!-- Service card: Glazenwassen -->
          <a href="/diensten/glazenwassen/" class="scroll-fade-up card-lift bg-bg rounded-lg border border-border shadow-card p-7 flex flex-col" style="border-radius: var(--radius-lg);">
            <div class="w-10 h-10 rounded-md bg-primary-100 flex items-center justify-center mb-4" style="border-radius: var(--radius-md);">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"/>
              </svg>
            </div>
            <h3 class="text-[18px] font-bold text-text mb-2">Glazenwassen</h3>
            <p class="text-[14px] text-text-muted leading-relaxed mb-4 flex-grow">Ramen wassen inclusief kozijnen. Tot 12 meter hoogte met het Telewash-systeem. Veilig en snel.</p>
            <span class="text-primary text-[14px] font-semibold inline-flex items-center gap-1.5 group-hover:gap-2.5 transition-all duration-200">
              Meer informatie
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>

          <!-- Service card: Bouw-oplevering -->
          <a href="/diensten/bouw-oplevering/" class="scroll-fade-up card-lift bg-bg rounded-lg border border-border shadow-card p-7 flex flex-col" style="border-radius: var(--radius-lg);">
            <div class="w-10 h-10 rounded-md bg-primary-100 flex items-center justify-center mb-4" style="border-radius: var(--radius-md);">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
            </div>
            <h3 class="text-[18px] font-bold text-text mb-2">Bouw-oplevering</h3>
            <p class="text-[14px] text-text-muted leading-relaxed mb-4 flex-grow">Grondige eindreiniging na verbouwing of nieuwbouw. Stof, bouwresten en vlekken verwijderd. Klaar voor gebruik.</p>
            <span class="text-primary text-[14px] font-semibold inline-flex items-center gap-1.5 transition-all duration-200">
              Meer informatie
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════
         SECTION 4: WERKWIJZE — bg: white, pt:80 pb:112
         Grid: repeat(3, 1fr), gap 32px
         Effects: stagger fade-up
         Decorative: oversized step numbers (DESIGN.md §7.5), connector line
         ═══════════════════════════════════════════════ -->
    <section class="bg-bg" style="padding-top: 80px; padding-bottom: 112px;">
      <div class="max-w-[1360px] mx-auto px-5 md:px-10">

        <!-- Section header -->
        <div class="scroll-fade-up text-center mb-12">
          <span class="kicker">WERKWIJZE</span>
          <h2>Hoe werkt het?</h2>
          <p class="text-text-muted text-[17px] mt-3 max-w-lg mx-auto">Van eerste contact tot je vaste schoonmaakteam in drie stappen.</p>
        </div>

        <!-- Timeline steps -->
        <div class="stagger-container grid grid-cols-1 md:grid-cols-3 gap-8 relative">
          <!-- Connector line (hidden on mobile) -->
          <div class="hidden md:block absolute top-16 left-[16.6%] right-[16.6%] h-0.5 bg-border" aria-hidden="true" style="z-index: 0;"></div>

          <!-- Step 1 -->
          <div class="relative text-center" style="z-index: 1;">
            <!-- Oversized bg number (DESIGN.md §7.5) -->
            <div class="absolute hidden md:block pointer-events-none select-none" style="top: -12px; left: 50%; transform: translateX(-50%); font-family: var(--font-head); font-size: 128px; font-weight: 900; color: var(--color-primary); opacity: 0.04; line-height: 1; z-index: 0;" aria-hidden="true">1</div>
            <div class="relative z-10 bg-bg rounded-lg p-6" style="border-radius: var(--radius-lg);">
              <div class="w-12 h-12 mx-auto rounded-full bg-primary text-white flex items-center justify-center font-head text-[18px] font-bold mb-4">1</div>
              <h3 class="text-[18px] font-bold text-text mb-2">Vrijblijvende offerte</h3>
              <p class="text-[14px] text-text-muted leading-relaxed mb-3">Vul het formulier in of bel gerust. We nemen binnen 24 uur contact op, geheel vrijblijvend.</p>
              <span class="inline-block text-[12px] font-semibold text-primary bg-primary-100 border border-sky-200 px-3 py-1 rounded-full">Reactie binnen 24 uur</span>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="relative text-center" style="z-index: 1;">
            <div class="absolute hidden md:block pointer-events-none select-none" style="top: -12px; left: 50%; transform: translateX(-50%); font-family: var(--font-head); font-size: 128px; font-weight: 900; color: var(--color-primary); opacity: 0.04; line-height: 1; z-index: 0;" aria-hidden="true">2</div>
            <div class="relative z-10 bg-bg rounded-lg p-6" style="border-radius: var(--radius-lg);">
              <div class="w-12 h-12 mx-auto rounded-full bg-primary-light text-white flex items-center justify-center font-head text-[18px] font-bold mb-4">2</div>
              <h3 class="text-[18px] font-bold text-text mb-2">Locatiebezoek en plan</h3>
              <p class="text-[14px] text-text-muted leading-relaxed mb-3">We komen langs, bekijken je pand en stellen een schoonmaakplan op maat samen. Heldere offerte, geen verborgen kosten.</p>
              <span class="inline-block text-[12px] font-semibold text-primary bg-primary-100 border border-sky-200 px-3 py-1 rounded-full">Offerte binnen 24 uur</span>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="relative text-center" style="z-index: 1;">
            <div class="absolute hidden md:block pointer-events-none select-none" style="top: -12px; left: 50%; transform: translateX(-50%); font-family: var(--font-head); font-size: 128px; font-weight: 900; color: var(--color-primary); opacity: 0.04; line-height: 1; z-index: 0;" aria-hidden="true">3</div>
            <div class="relative z-10 bg-bg rounded-lg p-6" style="border-radius: var(--radius-lg);">
              <div class="w-12 h-12 mx-auto rounded-full bg-primary text-white flex items-center justify-center font-head text-[18px] font-bold mb-4">3</div>
              <h3 class="text-[18px] font-bold text-text mb-2">Vaste teams aan het werk</h3>
              <p class="text-[14px] text-text-muted leading-relaxed mb-3">Je vaste schoonmaakteam begint op de afgesproken dag. Altijd dezelfde mensen die je pand kennen.</p>
