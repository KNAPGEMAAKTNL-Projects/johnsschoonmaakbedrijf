---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact & offerte aanvragen"
  description="Neem contact op met John's Schoonmaakbedrijf voor een vrijblijvende offerte. Bel, mail of vul het formulier in."
>
  <section class="bg-primary-900 py-16 md:py-20">
    <div class="container-site">
      <span class="section-label text-primary-300">Contact</span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white mt-3 mb-6 max-w-2xl">
        Offerte aanvragen
      </h1>
      <p class="text-primary-200 text-lg max-w-2xl leading-relaxed">
        Vertel ons over uw wensen. Wij nemen snel contact met u op voor een vrijblijvend gesprek en een offerte op maat.
      </p>
    </div>
  </section>

  <section class="py-20 md:py-24 bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-14">
        <!-- Contact form  - 3 columns -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-extrabold mb-6">Stuur ons een bericht</h2>
          <form id="contact-form" class="space-y-5" action="#" method="POST" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="naam" class="block text-sm font-medium text-text mb-1.5">Naam *</label>
                <input
                  type="text"
                  id="naam"
                  name="naam"
                  required
                  autocomplete="name"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-shadow"
                  placeholder="Uw naam"
                />
              </div>
              <div>
                <label for="bedrijf" class="block text-sm font-medium text-text mb-1.5">Bedrijfsnaam</label>
                <input
                  type="text"
                  id="bedrijf"
                  name="bedrijf"
                  autocomplete="organization"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-shadow"
                  placeholder="Uw bedrijf"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="email" class="block text-sm font-medium text-text mb-1.5">E-mailadres *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-shadow"
                  placeholder="uw@email.nl"
                />
              </div>
              <div>
                <label for="telefoon" class="block text-sm font-medium text-text mb-1.5">Telefoonnummer *</label>
                <input
                  type="tel"
                  id="telefoon"
                  name="telefoon"
                  required
                  autocomplete="tel"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-shadow"
                  placeholder="06 1234 5678"
                />
              </div>
            </div>

            <div>
              <label for="dienst" class="block text-sm font-medium text-text mb-1.5">Gewenste dienst</label>
              <select
                id="dienst"
                name="dienst"
                class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-text focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-shadow"
              >
                <option value="" disabled selected>Selecteer een dienst (optioneel)</option>
                <option value="bedrijfsschoonmaak">Bedrijfsschoonmaak</option>
                <option value="kantoorschoonmaak">Kantoorschoonmaak</option>
                <option value="glas-gevel">Glas- en gevelreiniging</option>
                <option value="onderwijsschoonmaak">Onderwijsschoonmaak</option>
                <option value="industrieel">Industriële schoonmaak</option>
                <option value="dagschoonmaak">Dagschoonmaak</option>
                <option value="anders">Anders</option>
              </select>
            </div>

            <div>
              <label for="bericht" class="block text-sm font-medium text-text mb-1.5">Uw bericht *</label>
              <textarea
                id="bericht"
                name="bericht"
                required
                rows="5"
                maxlength="2000"
                class="w-full px-4 py-3 rounded-lg border border-border bg-surface text-text placeholder-text-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-shadow resize-y"
                placeholder="Vertel ons over uw schoonmaakwensen, de locatie en eventuele bijzonderheden..."
              ></textarea>
            </div>

            <!-- Form feedback -->
            <div id="form-feedback" class="hidden" role="alert" aria-live="polite"></div>

            <button id="submit-btn" type="submit" class="btn-primary text-base py-4 px-8">
              <span id="submit-text">Verstuur aanvraag</span>
              <svg id="submit-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
              <svg id="submit-spinner" class="w-4 h-4 animate-spin hidden" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
            </button>
          </form>

          <script>
            const form = document.getElementById('contact-form') as HTMLFormElement;
            const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
            const submitText = document.getElementById('submit-text');
            const submitIcon = document.getElementById('submit-icon');
            const submitSpinner = document.getElementById('submit-spinner');
            const feedback = document.getElementById('form-feedback');

            form?.addEventListener('submit', (e) => {
              e.preventDefault();

              // Show loading state
              submitBtn.disabled = true;
              submitBtn.classList.add('opacity-70');
              submitText!.textContent = 'Verzenden...';
              submitIcon!.classList.add('hidden');
              submitSpinner!.classList.remove('hidden');

              // Simulate submission (replace with actual form handler)
              setTimeout(() => {
                feedback!.className = 'p-4 rounded-lg bg-green-50 border border-green-200 text-green-800 text-sm';
                feedback!.textContent = 'Bedankt voor uw aanvraag! Wij nemen zo snel mogelijk contact met u op.';
                feedback!.classList.remove('hidden');
                form.reset();

                // Reset button
                submitBtn.disabled = false;
                submitBtn.classList.remove('opacity-70');
                submitText!.textContent = 'Verstuur aanvraag';
                submitIcon!.classList.remove('hidden');
                submitSpinner!.classList.add('hidden');
              }, 1500);
            });
          </script>
        </div>

        <!-- Contact info sidebar  - 2 columns -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-extrabold mb-6">Direct contact</h2>
          <div class="space-y-6">
            <!-- Phone -->
            <a href="tel:+31623545276" class="flex items-start gap-4 p-5 bg-surface rounded-xl border border-border hover:border-primary-200 transition-colors group">
              <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-primary-100 transition-colors">
                <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <span class="block font-heading font-bold text-primary-900">Bel John direct</span>
                <span class="block text-primary-700 font-semibold">06 2354 5276</span>
                <span class="block text-text-muted text-sm mt-1">Persoonlijk contact, direct antwoord</span>
              </div>
            </a>

            <!-- Email -->
            <a href="mailto:info@JohnsGlazenwassersbedrijf.nl" class="flex items-start gap-4 p-5 bg-surface rounded-xl border border-border hover:border-primary-200 transition-colors group">
              <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-primary-100 transition-colors">
                <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <span class="block font-heading font-bold text-primary-900">E-mail</span>
                <span class="block text-primary-700 font-semibold text-sm">info@JohnsGlazenwassersbedrijf.nl</span>
              </div>
            </a>

            <!-- VCA badge -->
            <div class="p-5 bg-primary-50 rounded-xl border border-primary-100">
              <div class="flex items-center gap-3 mb-3">
                <svg class="w-6 h-6 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <span class="font-heading font-bold text-primary-900">VCA-gecertificeerd</span>
              </div>
              <p class="text-text-secondary text-sm leading-relaxed">
                Wij werken volgens de VCA-veiligheidsnormen. Dit betekent dat onze medewerkers getraind zijn in veilig werken en dat wij voldoen aan de eisen van de Veiligheid, Gezondheid en Milieu Checklist Aannemers.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
