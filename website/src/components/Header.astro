---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Diensten', href: '/diensten/' },
  { label: 'Over ons', href: '/over-ons/' },
  { label: 'Contact', href: '/contact/' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-border">
  <!-- Top bar with phone -->
  <div class="bg-primary-900 text-white">
    <div class="container-site flex items-center justify-between py-2 text-sm">
      <span class="hidden sm:inline text-primary-200">VCA-gecertificeerd schoonmaakbedrijf in de Betuwe</span>
      <div class="flex items-center gap-5 ml-auto">
        <a href="tel:+31623545276" class="flex items-center gap-1.5 hover:text-accent-300 transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          06 2354 5276
        </a>
        <a href="https://wa.me/31623545276" class="flex items-center gap-1.5 hover:text-accent-300 transition-colors" target="_blank" rel="noopener noreferrer">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
        <a href="mailto:info@JohnsGlazenwassersbedrijf.nl" class="hidden md:flex items-center gap-1.5 hover:text-accent-300 transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          info@JohnsGlazenwassersbedrijf.nl
        </a>
      </div>
    </div>
  </div>

  <!-- Main navigation -->
  <div class="container-site">
    <nav class="flex items-center justify-between py-4">
      <a href="/" class="flex items-center gap-3 group" aria-label="John's Schoonmaakbedrijf  - Home">
        <div class="w-10 h-10 bg-primary-700 rounded-lg flex items-center justify-center text-white font-heading font-extrabold text-lg transition-colors group-hover:bg-primary-800">
          J
        </div>
        <div class="hidden sm:block">
          <span class="block font-heading font-bold text-primary-900 text-lg leading-tight">John's</span>
          <span class="block text-text-secondary text-xs tracking-wide">Schoonmaakbedrijf</span>
        </div>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'font-heading font-medium text-sm transition-colors relative',
              currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                ? 'text-primary-700 after:absolute after:bottom-[-4px] after:left-0 after:w-full after:h-0.5 after:bg-primary-700'
                : 'text-text-secondary hover:text-primary-700',
            ]}
          >
            {item.label}
          </a>
        ))}
        <a href="/contact/" class="btn-primary text-sm py-2.5 px-5">
          Offerte aanvragen
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 min-w-[44px] min-h-[44px] flex items-center justify-center text-text-secondary hover:text-primary-700 transition-colors"
        aria-label="Menu openen"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-border bg-white">
    <div class="container-site py-4 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block py-3 px-4 rounded-lg font-heading font-medium text-sm transition-colors',
            currentPath === item.href
              ? 'bg-primary-50 text-primary-700'
              : 'text-text-secondary hover:bg-surface-alt hover:text-primary-700',
          ]}
        >
          {item.label}
        </a>
      ))}
      <div class="pt-3">
        <a href="/contact/" class="btn-primary w-full justify-center text-sm py-3">
          Offerte aanvragen
        </a>
      </div>
      <div class="pt-2">
        <a href="tel:+31623545276" class="flex items-center justify-center gap-2 py-3 text-primary-700 font-heading font-semibold text-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Bel direct: 06 2354 5276
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
