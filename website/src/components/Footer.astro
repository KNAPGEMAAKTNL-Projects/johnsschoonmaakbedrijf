---
const services = [
  { label: 'Bedrijfsschoonmaak', href: '/diensten/bedrijfsschoonmaak/' },
  { label: 'Glas- en gevelreiniging', href: '/diensten/glas-en-gevelreiniging/' },
  { label: 'Kantoorschoonmaak', href: '/diensten/kantoorschoonmaak/' },
  { label: 'Onderwijsschoonmaak', href: '/diensten/onderwijsschoonmaak/' },
  { label: 'Industriële schoonmaak', href: '/diensten/industriele-schoonmaak/' },
  { label: 'Dagschoonmaak', href: '/diensten/dagschoonmaak/' },
];

const regions = [
  'Tiel', 'Culemborg', 'Geldermalsen', 'Leerdam', 'Buren',
  'Waardenburg', 'Vianen', 'Asperen', 'Beesd', 'Haaften',
];
---

<footer class="bg-primary-900 text-primary-100">
  <div class="container-site py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center text-white font-heading font-extrabold text-lg">
            J
          </div>
          <div>
            <span class="block font-heading font-bold text-white text-lg leading-tight">John's</span>
            <span class="block text-primary-300 text-xs tracking-wide">Schoonmaakbedrijf</span>
          </div>
        </div>
        <p class="text-primary-300 text-sm leading-relaxed mb-6">
          Al sinds 2007 de betrouwbare schoonmaakpartner voor bedrijven in de Betuwe. Persoonlijk, vakkundig en altijd met aandacht voor kwaliteit.
        </p>
        <div class="flex items-center gap-2 px-3 py-2 bg-white/5 rounded-lg border border-white/10 w-fit">
          <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span class="text-sm font-medium text-white">VCA-gecertificeerd</span>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h3 class="font-heading font-bold text-white text-sm uppercase tracking-wider mb-5">Diensten</h3>
        <ul class="space-y-3">
          {services.map((service) => (
            <li>
              <a href={service.href} class="text-primary-300 text-sm hover:text-white transition-colors">
                {service.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Werkgebied column -->
      <div>
        <h3 class="font-heading font-bold text-white text-sm uppercase tracking-wider mb-5">Werkgebied</h3>
        <div class="flex flex-wrap gap-2">
          {regions.map((region) => (
            <span class="text-primary-300 text-sm bg-white/5 px-2.5 py-1 rounded">
              {region}
            </span>
          ))}
          <span class="text-primary-400 text-sm px-2.5 py-1">en omstreken</span>
        </div>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="font-heading font-bold text-white text-sm uppercase tracking-wider mb-5">Contact</h3>
        <ul class="space-y-4">
          <li>
            <a href="tel:+31623545276" class="flex items-start gap-3 text-primary-300 hover:text-white transition-colors group">
              <svg class="w-5 h-5 mt-0.5 text-accent group-hover:text-accent-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <div>
                <span class="block text-sm font-medium text-white">Bel John direct</span>
                <span class="block text-sm">06 2354 5276</span>
              </div>
            </a>
          </li>
          <li>
            <a href="https://wa.me/31623545276" class="flex items-start gap-3 text-primary-300 hover:text-white transition-colors group" target="_blank" rel="noopener noreferrer">
              <svg class="w-5 h-5 mt-0.5 text-accent group-hover:text-accent-300" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <div>
                <span class="block text-sm font-medium text-white">WhatsApp</span>
                <span class="block text-sm">Stuur een bericht</span>
              </div>
            </a>
          </li>
          <li>
            <a href="mailto:info@JohnsGlazenwassersbedrijf.nl" class="flex items-start gap-3 text-primary-300 hover:text-white transition-colors">
              <svg class="w-5 h-5 mt-0.5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span class="text-sm">info@JohnsGlazenwassersbedrijf.nl</span>
            </a>
          </li>
        </ul>

        <div class="mt-8">
          <a href="/contact/" class="btn-primary w-full justify-center text-sm py-3 bg-accent hover:bg-accent-700">
            Offerte aanvragen
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="container-site py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-primary-400 text-xs">
      <span>&copy; {new Date().getFullYear()} John's Schoonmaakbedrijf. Alle rechten voorbehouden.</span>
      <div class="flex gap-5">
        <a href="/privacy/" class="hover:text-white transition-colors">Privacybeleid</a>
        <a href="/voorwaarden/" class="hover:text-white transition-colors">Algemene voorwaarden</a>
      </div>
    </div>
  </div>
</footer>

<!-- Mobile sticky CTA bar -->
<div class="fixed bottom-0 left-0 right-0 z-40 md:hidden bg-white border-t border-border shadow-lg">
  <div class="flex">
    <a href="tel:+31623545276" class="flex-1 flex items-center justify-center gap-2 py-3.5 min-h-[48px] text-primary-700 font-heading font-semibold text-sm border-r border-border">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      Bellen
    </a>
    <a href="https://wa.me/31623545276" class="flex-1 flex items-center justify-center gap-2 py-3.5 min-h-[48px] text-green-700 font-heading font-semibold text-sm border-r border-border" target="_blank" rel="noopener noreferrer">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>
    <a href="/contact/" class="flex-1 flex items-center justify-center gap-2 py-3.5 min-h-[48px] bg-primary-700 text-white font-heading font-semibold text-sm">
      Offerte
    </a>
  </div>
</div>
