---
/**
 * Hero  - Confident statement approach (CSU-inspired, EW-calm)
 * "De schoonmaakpartner van de Betuwe"
 * Steady energy, clean confidence, VCA badge, dual CTA
 */
---

<section class="relative bg-primary-900 overflow-hidden">
  <!-- Subtle background texture -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')"></div>

  <div class="container-site relative">
    <div class="py-20 md:py-28 lg:py-32 max-w-3xl">
      <!-- VCA badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/10 rounded-full text-primary-200 text-sm mb-8 backdrop-blur-sm">
        <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        VCA-gecertificeerd sinds 2007
      </div>

      <!-- Headline -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.1] mb-6">
        De schoonmaak&shy;partner van
        <span class="text-accent">de Betuwe</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl text-primary-200 leading-relaxed mb-10 max-w-2xl">
        Professionele bedrijfsschoonmaak met persoonlijke aandacht. Een vast team dat uw pand kent, zodat u zich kunt richten op wat écht belangrijk is.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact/" class="btn-primary bg-accent hover:bg-accent-700 text-primary-900 text-base py-4 px-8">
          Offerte aanvragen
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="tel:+31623545276" class="btn-secondary border-white/20 text-white hover:bg-white/10 hover:text-white text-base py-4 px-8">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Bel John direct
        </a>
      </div>
    </div>
  </div>

  <!-- Photo area  - placeholder for real team photography -->
  <div class="absolute right-0 top-0 bottom-0 w-1/3 hidden lg:block">
    <div class="h-full bg-gradient-to-l from-primary-800/50 to-transparent flex items-center justify-center">
      <div class="text-primary-500/30 text-center p-8">
        <svg class="w-24 h-24 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class="text-sm font-heading">Team foto<br/>komt hier</p>
      </div>
    </div>
  </div>
</section>
