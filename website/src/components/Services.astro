---
/**
 * Services overview  - card-based, comprehensive (TopCleaners density)
 * Each links to a dedicated service page for SEO depth
 */
const services = [
  {
    title: 'Bedrijfsschoonmaak',
    description: 'Dagelijks of periodiek onderhoud van uw bedrijfspand. Een schone werkplek voor tevreden medewerkers en een professionele uitstraling.',
    href: '/diensten/bedrijfsschoonmaak/',
    icon: 'building',
  },
  {
    title: 'Glas- en gevelreiniging',
    description: 'Streepvrije ramen en een schone gevel maken het verschil. Met professionele apparatuur en osmosewater voor een vlekkeloos resultaat.',
    href: '/diensten/glas-en-gevelreiniging/',
    icon: 'sparkles',
  },
  {
    title: 'Kantoorschoonmaak',
    description: 'Een opgeruimd en hygiënisch kantoor verhoogt de productiviteit. Wij zorgen voor een frisse werkomgeving, dag na dag.',
    href: '/diensten/kantoorschoonmaak/',
    icon: 'desktop',
  },
  {
    title: 'Onderwijsschoonmaak',
    description: 'Scholen en kinderopvang vragen om extra aandacht voor hygiëne. Wij werken volgens de richtlijnen en met de juiste middelen.',
    href: '/diensten/onderwijsschoonmaak/',
    icon: 'academic',
  },
  {
    title: 'Industriële schoonmaak',
    description: 'Productieruimtes, werkplaatsen en magazijnen. Wij hebben de ervaring en apparatuur voor intensieve reiniging.',
    href: '/diensten/industriele-schoonmaak/',
    icon: 'cog',
  },
  {
    title: 'Dagschoonmaak',
    description: 'Schoonmaak overdag, zichtbaar voor uw medewerkers en bezoekers. Directe aandacht voor wat nodig is, wanneer het nodig is.',
    href: '/diensten/dagschoonmaak/',
    icon: 'sun',
  },
];

const icons: Record<string, string> = {
  building: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />',
  sparkles: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />',
  desktop: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
  academic: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />',
  cog: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />',
  sun: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />',
};
---

<section class="py-20 md:py-24 bg-surface" id="diensten">
  <div class="container-site">
    <div class="text-center mb-14">
      <span class="section-label">Onze diensten</span>
      <h2 class="text-3xl md:text-4xl font-extrabold mt-3 mb-4">
        Professionele schoonmaak voor elke situatie
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        Van dagelijks kantooronderhoud tot intensieve industriële reiniging  - wij bieden een compleet pakket schoonmaakdiensten voor de zakelijke markt.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <a
          href={service.href}
          class="group bg-white rounded-xl p-7 border border-border hover:border-primary-200 transition-all duration-300 hover:shadow-lg hover:shadow-primary-100/50"
        >
          <div class="w-12 h-12 bg-primary-50 rounded-lg flex items-center justify-center mb-5 group-hover:bg-primary-100 transition-colors">
            <svg class="w-6 h-6 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[service.icon]} />
          </div>
          <h3 class="font-heading font-bold text-lg text-primary-900 mb-2 group-hover:text-primary-700 transition-colors">
            {service.title}
          </h3>
          <p class="text-text-secondary text-sm leading-relaxed mb-4">
            {service.description}
          </p>
          <span class="inline-flex items-center gap-1.5 text-primary-700 text-sm font-semibold font-heading group-hover:gap-2.5 transition-all">
            Meer informatie
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
