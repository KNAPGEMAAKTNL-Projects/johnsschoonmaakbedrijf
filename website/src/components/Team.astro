---
/**
 * Team section  - team story personality (answer #9)
 * "Maak kennis met ons team"  - personal advantage over faceless competitors
 */
const team = [
  {
    name: 'John Hak',
    role: 'Eigenaar & oprichter',
    description: 'Sinds 2007 het gezicht van het bedrijf. John staat voor vakmanschap, eerlijkheid en persoonlijk contact met elke klant.',
  },
  {
    name: 'Egbert van Zijl',
    role: 'Medewerker schoonmaak',
    description: 'Ervaren kracht met oog voor detail. Egbert zorgt ervoor dat elk pand er weer piekfijn uitziet.',
  },
  {
    name: 'Benny Mulder',
    role: 'Medewerker schoonmaak',
    description: 'Betrouwbaar en nauwkeurig. Benny weet precies wat nodig is om uw bedrijfsruimte in topconditie te houden.',
  },
];
---

<section class="py-20 md:py-24 bg-surface">
  <div class="container-site">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-center">
      <!-- Text side -->
      <div>
        <span class="section-label">Ons team</span>
        <h2 class="text-3xl md:text-4xl font-extrabold mt-3 mb-6">
          Maak kennis met de mensen achter John's
        </h2>
        <p class="text-text-secondary text-lg leading-relaxed mb-8">
          Wij geloven dat goed schoonmaken begint bij goede mensen. Ons kleine, hechte team kent uw pand en uw wensen. U weet altijd wie er komt  - en dat is voor ons vanzelfsprekend.
        </p>

        <div class="space-y-6">
          {team.map((member) => (
            <div class="flex gap-4">
              <!-- Photo placeholder -->
              <div class="flex-shrink-0 w-14 h-14 bg-primary-100 rounded-full flex items-center justify-center">
                <span class="font-heading font-bold text-primary-700 text-lg">
                  {member.name.split(' ').map(n => n[0]).join('')}
                </span>
              </div>
              <div>
                <h3 class="font-heading font-bold text-primary-900">{member.name}</h3>
                <p class="text-primary-600 text-sm font-medium mb-1">{member.role}</p>
                <p class="text-text-secondary text-sm leading-relaxed">{member.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Photo placeholder -->
      <div class="bg-primary-50 rounded-2xl aspect-[4/3] flex items-center justify-center border-2 border-dashed border-primary-200">
        <div class="text-center text-primary-400 p-8">
          <svg class="w-20 h-20 mx-auto mb-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <p class="font-heading font-semibold text-sm">Teamfoto komt hier</p>
          <p class="text-xs mt-1">Het team aan het werk bij een klant</p>
        </div>
      </div>
    </div>
  </div>
</section>
