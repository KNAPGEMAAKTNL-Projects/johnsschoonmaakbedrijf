---
/**
 * Reusable service page layout  - dedicated pages for SEO (answer #8)
 * Each service gets its own page with tailored content and CTA
 */
import CTA from './CTA.astro';

interface Props {
  title: string;
  subtitle: string;
  intro: string;
  features: { title: string; description: string }[];
  process?: { step: string; description: string }[];
}

const { title, subtitle, intro, features, process } = Astro.props;
---

<!-- Page header -->
<section class="bg-primary-900 py-16 md:py-20">
  <div class="container-site">
    <div class="flex items-center gap-2 text-primary-300 text-sm mb-4">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
      <a href="/diensten/" class="hover:text-white transition-colors">Diensten</a>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-white">{title}</span>
    </div>
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white mt-3 mb-6 max-w-3xl">
      {title}
    </h1>
    <p class="text-primary-200 text-lg max-w-2xl leading-relaxed">
      {subtitle}
    </p>
  </div>
</section>

<!-- Content -->
<section class="py-20 md:py-24 bg-white">
  <div class="container-site">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-14">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <!-- Photo placeholder -->
        <div class="bg-primary-50 rounded-2xl aspect-[16/9] flex items-center justify-center border-2 border-dashed border-primary-200 mb-10">
          <div class="text-center text-primary-400 p-8">
            <svg class="w-16 h-16 mx-auto mb-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="font-heading font-semibold text-sm">Foto komt hier</p>
          </div>
        </div>

        <div class="prose prose-lg text-text-secondary leading-relaxed mb-12">
          <p set:html={intro} />
        </div>

        <!-- Features -->
        <h2 class="text-2xl font-extrabold mb-8">Wat u kunt verwachten</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-12">
          {features.map((feature) => (
            <div class="bg-surface rounded-xl p-6 border border-border">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary-700 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <h3 class="font-heading font-bold text-primary-900 mb-1">{feature.title}</h3>
                  <p class="text-text-secondary text-sm leading-relaxed">{feature.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        {process && process.length > 0 && (
          <>
            <h2 class="text-2xl font-extrabold mb-8">Onze werkwijze</h2>
            <div class="space-y-6">
              {process.map((item, index) => (
                <div class="flex gap-5">
                  <div class="flex-shrink-0 w-10 h-10 bg-primary-700 rounded-full flex items-center justify-center text-white font-heading font-bold text-sm">
                    {index + 1}
                  </div>
                  <div class="pt-1">
                    <h3 class="font-heading font-bold text-primary-900 mb-1">{item.step}</h3>
                    <p class="text-text-secondary text-sm leading-relaxed">{item.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </>
        )}
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1">
        <div class="sticky top-28 space-y-6">
          <!-- CTA card -->
          <div class="bg-primary-50 rounded-xl p-7 border border-primary-100">
            <h3 class="font-heading font-bold text-primary-900 text-lg mb-3">Offerte aanvragen</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-5">
              Wij komen graag langs om uw wensen te bespreken en een vrijblijvende offerte op maat te maken.
            </p>
            <a href="/contact/" class="btn-primary w-full justify-center text-sm py-3 mb-3">
              Offerte aanvragen
            </a>
            <a href="tel:+31623545276" class="btn-secondary w-full justify-center text-sm py-3">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              06 2354 5276
            </a>
          </div>

          <!-- VCA badge -->
          <div class="bg-white rounded-xl p-5 border border-border">
            <div class="flex items-center gap-3">
              <svg class="w-8 h-8 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div>
                <span class="block font-heading font-bold text-primary-900 text-sm">VCA-gecertificeerd</span>
                <span class="block text-text-muted text-xs">Veilig en verantwoord werken</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<CTA />
